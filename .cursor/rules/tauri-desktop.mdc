## Common Patterns

### Async Command Handlers

```rust
#[tauri::command]
async fn long_running_task(
    window: tauri::Window,
    app: tauri::AppHandle,
) -> Result<String, String> {
    // Emit progress updates
    window.emit("progress", serde_json::json!({"value": 25})).unwrap();

    tokio::time::sleep(tokio::time::Duration::from_secs(1)).await;

    window.emit("progress", serde_json::json!({"value": 50})).unwrap();

    Ok("completed".to_string())
}
```

### Error Handling in Commands

```rust
#[tauri::command]
fn risky_operation() -> Result<String, String> {
    if some_condition {
        Ok("success".to_string())
    } else {
        Err("operation failed: condition not met".to_string())
    }
}
```

