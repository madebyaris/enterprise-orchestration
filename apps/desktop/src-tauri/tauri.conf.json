{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Enterprise Orchestration",
  "version": "0.1.0",
  "identifier": "com.madebyaris.enterpriseorchestration",
  "build": {
    "frontendDist": "../../control-ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --dir ../control-ui dev --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "pnpm --dir ../control-ui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Enterprise Orchestration",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ]
  }
}
